{
  "name": "gmail-subscription-cleanup",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node generate-icons.mjs",
    "build": "node generate-icons.mjs && node -e \"require('fs').copyFileSync('manifest.source.json','manifest.json')\" && tsc -b && vite build",
    "preview": "vite preview",
    "package": "npm run build && node pack.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.272",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.5.3",
    "vite": "^4.5.3"
  }
}
